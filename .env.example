# Secrets — configure via `wrangler secret put` (nunca no repo)
# SUPABASE_SERVICE_ROLE_KEY=

# IA — provider OpenAI-compatível, usado nas server functions.
# Default (sem AI_GATEWAY_URL): API direta do Google AI Studio (Gemini).
# AI_GATEWAY_URL="https://generativelanguage.googleapis.com/v1beta/openai"   # opcional (já é o default)
# AI_API_KEY=        # chave do Google AI Studio (aistudio.google.com/apikey) — OBRIGATÓRIA p/ IA

# Integrações diretas (secrets no Worker — wrangler secret put)
# HUBSPOT_API_KEY=   # token de Private App do HubSpot (sync de contatos no signup)
# TELEGRAM_API_KEY=  # bot token do BotFather (bot de entrevistas)
