# Secrets — configure via `wrangler secret put` (nunca no repo)
# SUPABASE_SERVICE_ROLE_KEY=

# IA — provider OpenAI-compatível (opcional), usado nas server functions.
# Sem nada disso, usa o gateway do Lovable + LOVABLE_API_KEY (fallback).
# Para sair do Lovable na IA, basta setar estes 2 (ex.: OpenRouter):
# AI_GATEWAY_URL="https://openrouter.ai/api/v1"   # var/secret no Worker
# AI_API_KEY=                                      # secret no Worker (wrangler secret put)
# LOVABLE_API_KEY=   # secret no Worker — IA (fallback) + integrações HubSpot/Telegram (ainda via Lovable)
